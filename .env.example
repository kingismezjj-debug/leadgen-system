# Google Places API New. Enable Places API in Google Cloud first.
GOOGLE_MAPS_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
PLACES_LANGUAGE_CODE=zh-CN
PLACES_REGION_CODE=US

# Local API
LEADGEN_API_HOST=127.0.0.1
LEADGEN_API_PORT=8790
LEADGEN_WEB_ORIGIN=http://127.0.0.1:5190
# Optional but strongly recommended. Use a long random value and enter it in the web UI per browser session.
LEADGEN_ADMIN_TOKEN=

# Optional email delivery. Real sending is disabled unless one provider is configured.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional Jarvis-compatible email adapter. Expects POST JSON for each message.
JARVIS_EMAIL_ENDPOINT=
JARVIS_EMAIL_TOKEN=

# Compliance footer link. Use your own unsubscribe/preferences endpoint in production.
# Required for real sending. Must be a public HTTPS endpoint routed to this API's /unsubscribe path.
UNSUBSCRIBE_URL=https://mail.example.org/unsubscribe
EMAIL_DAILY_LIMIT=25
