    "sanitize-html": "^2.17.6",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "typescript": "~6.0.2"
